Attribute VB_Name = "AIChatModule"
Option Explicit

Sub LaunchAIChat()
    ' Extract embedded HTML and open in browser
    Dim htmlPath As String
    Dim fso As Object
    Dim file As Object
    Dim htmlContent As String
    
    ' Create temp file
    htmlPath = Environ("TEMP") & "\pdfclaw_chat.html"
    
    ' HTML content (embedded)
    htmlContent = "<!DOCTYPE html>" & vbCrLf & "<html lang=""en"">" & vbCrLf & "<head>" & vbCrLf & "<meta charset=""UTF-8"">" & vbCrLf & "<meta name=""viewport"" content=""width=device-width, initial-scale=1.0"">" & vbCrLf & "<title>PDFClaw AI Chat</title>" & vbCrLf & "<style>" & vbCrLf & "* { margin: 0; padding: 0; box-sizing: border-box; }" & vbCrLf & "body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f0f1a; color: #e0e0e0; height: 100vh; display: flex; flex-direction: column; }" & vbCrLf & ".header { background: #1a1a2e; padding: 12px 16px; border-bottom: 1px solid #2a2a4e; }" & vbCrLf & ".header h1 { font-size: 18px; color: #fff; }" & vbCrLf & ".header p { font-size: 10px; color: #888; margin-top: 2px; }" & vbCrLf & ".api-key-area { background: #16213e; padding: 12px 16px; border-bottom: 1px solid #2a2a4e; display: flex; gap: 8px; align-items: center; }" & vbCrLf & ".api-key-area input { flex: 1; background: #0f0f1a; border: 1px solid #2a2a4e; color: #fff; padding: 8px 12px; border-radius: 4px; font-size: 12px; outline: none; }" & vbCrLf & ".api-key-area input:focus { border-color: #e94560; }" & vbCrLf & ".api-key-area button { background: #e94560; color: #fff; border: none; padding: 8px 16px; border-radius: 4px; font-size: 12px; cursor: pointer; }" & vbCrLf & ".api-key-area button:hover { background: #d63851; }" & vbCrLf & ".api-key-area .saved { color: #7fff7f; font-size: 11px; }" & vbCrLf & ".chat { flex: 1; overflow-y: auto; padding: 12px 16px; display: flex; flex-direction: column; gap: 8px; }" & vbCrLf & ".msg { max-width: 85%; padding: 10px 14px; border-radius: 10px; line-height: 1.4; font-size: 13px; white-space: pre-wrap; word-wrap: break-word; }" & vbCrLf & ".msg.user { background: #e94560; color: #fff; align-self: flex-end; border-bottom-right-radius: 4px; }" & vbCrLf & ".msg.ai { background: #16213e; color: #e0e0e0; align-self: flex-start; border-bottom-left-radius: 4px; }" & vbCrLf & ".msg.system { background: #2a2a4e; color: #888; align-self: center; font-size: 11px; text-align: center; }" & vbCrLf & ".msg.tool { background: #1a3a1a; color: #7fff7f; align-self: flex-start; font-size: 11px; font-family: monospace; }" & vbCrLf & ".msg.error { background: #4a1a1a; color: #ff6b6b; }" & vbCrLf & ".input-area { background: #1a1a2e; padding: 12px 16px; border-top: 1px solid #2a2a4e; display: flex; gap: 8px; }" & vbCrLf & ".input-area input { flex: 1; background: #0f0f1a; border: 1px solid #2a2a4e; color: #fff; padding: 10px 14px; border-radius: 6px; font-size: 13px; outline: none; }" & vbCrLf & ".input-area input:focus { border-color: #e94560; }" & vbCrLf & ".input-area button { background: #e94560; color: #fff; border: none; padding: 10px 20px; border-radius: 6px; font-size: 13px; cursor: pointer; font-weight: 600; }" & vbCrLf & ".input-area button:hover { background: #d63851; }" & vbCrLf & ".input-area button:disabled { background: #555; cursor: not-allowed; }" & vbCrLf & ".typing { color: #888; font-style: italic; }" & vbCrLf & "</style>" & vbCrLf & "</head>" & vbCrLf & "<body>" & vbCrLf & "<div class=""header"">" & vbCrLf & "    <h1>PDFClaw AI Agent</h1>" & vbCrLf & "    <p>Model: Apriel-1.5-15b-Thinker | Tool Calling | Session Storage</p>" & vbCrLf & "</div>" & vbCrLf & "<div class=""api-key-area"">" & vbCrLf & "    <input type=""password"" id=""apiKeyInput"" placeholder=""Enter your Together API key..."" />" & vbCrLf & "    <button onclick=""saveApiKey()"">Save</button>" & vbCrLf & "    <span class=""saved"" id=""apiKeyStatus""></span>" & vbCrLf & "</div>" & vbCrLf & "<div class=""chat"" id=""chat"">" & vbCrLf & "    <div class=""msg system"">Welcome! Enter your Together API key above. Tools: weather, Wikipedia search, fetch URL, calculate, save/load data, time, tweets, generate content.</div>" & vbCrLf & "</div>" & vbCrLf & "<div class=""input-area"">" & vbCrLf & "    <input type=""text"" id=""input"" placeholder=""Type your message..."" autofocus />" & vbCrLf & "    <button id=""sendBtn"" onclick=""sendMessage()"">Send</button>" & vbCrLf & "</div>" & vbCrLf & "<script>" & vbCrLf & "const API_URL = ""https://api.together.xyz/v1/chat/completions"";" & vbCrLf & "const MODEL = ""ServiceNow-AI/Apriel-1.5-15b-Thinker"";" & vbCrLf & "" & vbCrLf & "const chatEl = document.getElementById(""chat"");" & vbCrLf & "const inputEl = document.getElementById(""input"");" & vbCrLf & "const sendBtn = document.getElementById(""sendBtn"");" & vbCrLf & "const apiKeyInput = document.getElementById(""apiKeyInput"");" & vbCrLf & "const apiKeyStatus = document.getElementById(""apiKeyStatus"");" & vbCrLf & "" & vbCrLf & "let API_KEY = sessionStorage.getItem('together_api_key') || '';" & vbCrLf & "if (API_KEY) {" & vbCrLf & "    apiKeyInput.value = API_KEY;" & vbCrLf & "    apiKeyStatus.textContent = 'Saved';" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "function saveApiKey() {" & vbCrLf & "    API_KEY = apiKeyInput.value.trim();" & vbCrLf & "    if (API_KEY) {" & vbCrLf & "        sessionStorage.setItem('together_api_key', API_KEY);" & vbCrLf & "        apiKeyStatus.textContent = 'Saved';" & vbCrLf & "    } else {" & vbCrLf & "        apiKeyStatus.textContent = 'Empty';" & vbCrLf & "    }" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "const sessionData = JSON.parse(sessionStorage.getItem('pdfclaw_data') || '{}');" & vbCrLf & "" & vbCrLf & "const tools = [" & vbCrLf & "    { type: ""function"", function: { name: ""get_weather"", description: ""Get current weather for a city"", parameters: { type: ""object"", properties: { city: { type: ""string"", description: ""City name"" } }, required: [""city""] } } }," & vbCrLf & "    { type: ""function"", function: { name: ""web_search"", description: ""Search Wikipedia for information"", parameters: { type: ""object"", properties: { query: { type: ""string"", description: ""Search query"" } }, required: [""query""] } } }," & vbCrLf & "    { type: ""function"", function: { name: ""fetch_url"", description: ""Fetch content from a URL"", parameters: { type: ""object"", properties: { url: { type: ""string"", description: ""URL to fetch"" } }, required: [""url""] } } }," & vbCrLf & "    { type: ""function"", function: { name: ""calculate"", description: ""Perform mathematical calculations"", parameters: { type: ""object"", properties: { expression: { type: ""string"", description: ""Math expression"" } }, required: [""expression""] } } }," & vbCrLf & "    { type: ""function"", function: { name: ""save_data"", description: ""Save data to session storage"", parameters: { type: ""object"", properties: { key: { type: ""string"" }, value: { type: ""string"" } }, required: [""key"", ""value""] } } }," & vbCrLf & "    { type: ""function"", function: { name: ""get_data"", description: ""Retrieve saved data"", parameters: { type: ""object"", properties: { key: { type: ""string"" } }, required: [""key""] } } }," & vbCrLf & "    { type: ""function"", function: { name: ""list_data"", description: ""List all saved data"", parameters: { type: ""object"", properties: {}, required: [] } } }," & vbCrLf & "    { type: ""function"", function: { name: ""get_current_time"", description: ""Get current date and time"", parameters: { type: ""object"", properties: {}, required: [] } } }," & vbCrLf & "    { type: ""function"", function: { name: ""generate_tweet"", description: ""Generate a tweet"", parameters: { type: ""object"", properties: { topic: { type: ""string"" }, style: { type: ""string"" } }, required: [""topic""] } } }," & vbCrLf & "    { type: ""function"", function: { name: ""generate_content"", description: ""Generate content"", parameters: { type: ""object"", properties: { type: { type: ""string"" }, topic: { type: ""string"" }, length: { type: ""string"" }, style: { type: ""string"" } }, required: [""type"", ""topic""] } } }" & vbCrLf & "];" & vbCrLf & "" & vbCrLf & "async function executeTool(toolName, args) {" & vbCrLf & "    switch(toolName) {" & vbCrLf & "        case ""get_weather"":" & vbCrLf & "            try {" & vbCrLf & "                const geoRes = await fetch('https://geocoding-api.open-meteo.com/v1/search?name=' + encodeURIComponent(args.city) + '&count=1');" & vbCrLf & "                const geoData = await geoRes.json();" & vbCrLf & "                if (!geoData.results || geoData.results.length === 0) return 'City not found';" & vbCrLf & "                const lat = geoData.results[0].latitude;" & vbCrLf & "                const lon = geoData.results[0].longitude;" & vbCrLf & "                const cityName = geoData.results[0].name;" & vbCrLf & "                const weatherRes = await fetch('https://api.open-meteo.com/v1/forecast?latitude=' + lat + '&longitude=' + lon + '&current_weather=true');" & vbCrLf & "                const weatherData = await weatherRes.json();" & vbCrLf & "                const cw = weatherData.current_weather;" & vbCrLf & "                return 'Weather in ' + cityName + ': ' + cw.temperature + 'C, Wind: ' + cw.windspeed + ' km/h';" & vbCrLf & "            } catch(e) { return 'Error: ' + e.message; }" & vbCrLf & "        case ""web_search"":" & vbCrLf & "            try {" & vbCrLf & "                const res = await fetch('https://en.wikipedia.org/api/rest_v1/page/summary/' + encodeURIComponent(args.query));" & vbCrLf & "                if (!res.ok) return 'Not found on Wikipedia';" & vbCrLf & "                const data = await res.json();" & vbCrLf & "                return 'Wikipedia: ' + data.title + '\n' + (data.extract || 'No summary');" & vbCrLf & "            } catch(e) { return 'Error: ' + e.message; }" & vbCrLf & "        case ""fetch_url"":" & vbCrLf & "            try {" & vbCrLf & "                let url = args.url;" & vbCrLf & "                if (!url.startsWith('http')) url = 'https://' + url;" & vbCrLf & "                const res = await fetch('https://api.allorigins.win/raw?url=' + encodeURIComponent(url));" & vbCrLf & "                if (!res.ok) return 'Could not fetch URL';" & vbCrLf & "                const html = await res.text();" & vbCrLf & "                const text = html.replace(/<script[^>]*>[\s\S]*?<\/script>/gi, '').replace(/<style[^>]*>[\s\S]*?<\/style>/gi, '').replace(/<[^>]+>/g, ' ').substring(0, 2000);" & vbCrLf & "                return 'Content: ' + text;" & vbCrLf & "            } catch(e) { return 'Error: ' + e.message; }" & vbCrLf & "        case ""calculate"":" & vbCrLf & "            try { return 'Result: ' + Function('""use strict""; return (' + args.expression + ')')(); } catch(e) { return 'Error: ' + e.message; }" & vbCrLf & "        case ""save_data"":" & vbCrLf & "            sessionData[args.key] = args.value;" & vbCrLf & "            sessionStorage.setItem('pdfclaw_data', JSON.stringify(sessionData));" & vbCrLf & "            return 'Saved: ' + args.key;" & vbCrLf & "        case ""get_data"":" & vbCrLf & "            return sessionData[args.key] ? 'Retrieved: ' + args.key + ' = ' + sessionData[args.key] : 'Not found';" & vbCrLf & "        case ""list_data"":" & vbCrLf & "            return Object.keys(sessionData).length ? 'Data: ' + JSON.stringify(sessionData) : 'No data saved';" & vbCrLf & "        case ""get_current_time"":" & vbCrLf & "            return 'Current time: ' + new Date().toLocaleString();" & vbCrLf & "        case ""generate_tweet"":" & vbCrLf & "            return 'Generate a tweet about ""' + args.topic + '"" (max 280 chars)';" & vbCrLf & "        case ""generate_content"":" & vbCrLf & "            return 'Generate a ' + (args.length || 'medium') + ' ' + args.type + ' about ""' + args.topic + '""';" & vbCrLf & "        default:" & vbCrLf & "            return 'Unknown tool';" & vbCrLf & "    }" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "let messages = [{ role: ""system"", content: ""You are a helpful AI assistant with access to tools. Use tools when needed. Be concise."" }];" & vbCrLf & "" & vbCrLf & "inputEl.addEventListener(""keydown"", function(e) { if (e.key === ""Enter"" && !sendBtn.disabled) sendMessage(); });" & vbCrLf & "" & vbCrLf & "function addMsg(text, cls) {" & vbCrLf & "    const div = document.createElement(""div"");" & vbCrLf & "    div.className = ""msg "" + cls;" & vbCrLf & "    div.textContent = text;" & vbCrLf & "    chatEl.appendChild(div);" & vbCrLf & "    chatEl.scrollTop = chatEl.scrollHeight;" & vbCrLf & "    return div;" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "async function sendMessage() {" & vbCrLf & "    const msg = inputEl.value.trim();" & vbCrLf & "    if (!msg) return;" & vbCrLf & "    if (!API_KEY) { addMsg(""Please enter your Together API key first!"", ""system""); apiKeyInput.focus(); return; }" & vbCrLf & "    addMsg(msg, ""user"");" & vbCrLf & "    inputEl.value = """";" & vbCrLf & "    sendBtn.disabled = true;" & vbCrLf & "    messages.push({ role: ""user"", content: msg });" & vbCrLf & "    const typing = addMsg(""Thinking..."", ""ai typing"");" & vbCrLf & "    try {" & vbCrLf & "        let response = await callAI();" & vbCrLf & "        typing.textContent = response;" & vbCrLf & "        typing.className = ""msg ai"";" & vbCrLf & "    } catch(e) {" & vbCrLf & "        typing.textContent = ""Error: "" + e.message;" & vbCrLf & "        typing.className = ""msg ai error"";" & vbCrLf & "    }" & vbCrLf & "    sendBtn.disabled = false;" & vbCrLf & "    inputEl.focus();" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "async function callAI() {" & vbCrLf & "    const res = await fetch(API_URL, {" & vbCrLf & "        method: ""POST""," & vbCrLf & "        headers: { ""Content-Type"": ""application/json"", ""Authorization"": ""Bearer "" + API_KEY }," & vbCrLf & "        body: JSON.stringify({ model: MODEL, messages: messages, tools: tools, tool_choice: ""auto"", max_tokens: 1024 })" & vbCrLf & "    });" & vbCrLf & "    if (!res.ok) throw new Error('API Error: ' + res.status);" & vbCrLf & "    const data = await res.json();" & vbCrLf & "    const assistantMsg = data.choices[0].message;" & vbCrLf & "    messages.push(assistantMsg);" & vbCrLf & "    if (assistantMsg.tool_calls && assistantMsg.tool_calls.length > 0) {" & vbCrLf & "        for (const tc of assistantMsg.tool_calls) {" & vbCrLf & "            addMsg('Tool: ' + tc.function.name, ""tool"");" & vbCrLf & "            const result = await executeTool(tc.function.name, JSON.parse(tc.function.arguments));" & vbCrLf & "            addMsg('Result: ' + result, ""tool"");" & vbCrLf & "            messages.push({ role: ""tool"", tool_call_id: tc.id, content: result });" & vbCrLf & "        }" & vbCrLf & "        const finalRes = await fetch(API_URL, {" & vbCrLf & "            method: ""POST""," & vbCrLf & "            headers: { ""Content-Type"": ""application/json"", ""Authorization"": ""Bearer "" + API_KEY }," & vbCrLf & "            body: JSON.stringify({ model: MODEL, messages: messages, max_tokens: 1024 })" & vbCrLf & "        });" & vbCrLf & "        const finalData = await finalRes.json();" & vbCrLf & "        messages.push(finalData.choices[0].message);" & vbCrLf & "        return finalData.choices[0].message.content;" & vbCrLf & "    }" & vbCrLf & "    return assistantMsg.content || ""No response"";" & vbCrLf & "}" & vbCrLf & "</script>" & vbCrLf & "</body>" & vbCrLf & "</html>"
    
    ' Write to file
    Set fso = CreateObject("Scripting.FileSystemObject")
    Set file = fso.CreateTextFile(htmlPath, True, True)  ' Unicode=True
    file.Write htmlContent
    file.Close
    
    ' Open in default browser
    CreateObject("Shell.Application").Open htmlPath
End Sub
