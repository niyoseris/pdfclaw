 <button id=""sendBtn"" onclick=""sendMessage()"">Send</button>" & vbCrLf & "</div>" & vbCrLf & "<script>" & vbCrLf & "const API_URL = ""https://api.together.xyz/v1/chat/completions"";" & vbCrLf & "const MODEL = ""ServiceNow-AI/Apriel-1.5-15b-Thinker"";" & vbCrLf & "" & vbCrLf & "const chatEl = document.getElementById(""chat"");" & vbCrLf & "const inputEl = document.getElementById(""input"");" & vbCrLf & "const sendBtn = document.getElementById(""sendBtn"");" & vbCrLf & "const apiKeyInput = document.getElementById(""apiKeyInput"");" & vbCrLf & "const apiKeyStatus = document.getElementById(""apiKeyStatus"");" & vbCrLf & "" & vbCrLf & "// Load saved API key" & vbCrLf & "let API_KEY = sessionStorage.getItem('together_api_key') || '';" & vbCrLf & "if (API_KEY) {" & vbCrLf & "    apiKeyInput.value = API_KEY;" & vbCrLf & "    apiKeyStatus.textContent = 'Saved';" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "function saveApiKey() {" & vbCrLf & "    API_KEY = apiKeyInput.value.trim();" & vbCrLf & "    if (API_KEY) {" & vbCrLf & "        sessionStorage.setItem('together_api_key', API_KEY);" & vbCrLf & "        apiKeyStatus.textContent = 'Saved';" & vbCrLf & "    } else {" & vbCrLf & "        apiKeyStatus.textContent = 'Empty';" & vbCrLf & "    }" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "// Session storage for user data" & vbCrLf & "const sessionData = JSON.parse(sessionStorage.getItem('pdfclaw_data') || '{}');" & vbCrLf & "" & vbCrLf & "// Define tools available to the AI" & vbCrLf & "const tools = [" & vbCrLf & "    {" & vbCrLf & "        type: ""function""," & vbCrLf & "        function: {" & vbCrLf & "            name: ""get_weather""," & vbCrLf & "            description: ""Get current weather for a city. Use this for weather queries.""," & vbCrLf & "            parameters: {" & vbCrLf & "                type: ""object""," & vbCrLf & "                properties: {" & vbCrLf & "                    city: { type: ""string"", description: ""City name, e.g. 'Nicosia', 'London'"" }" & vbCrLf & "                }," & vbCrLf & "                required: [""city""]" & vbCrLf & "            }" & vbCrLf & "        }" & vbCrLf & "    }," & vbCrLf & "    {" & vbCrLf & "        type: ""function""," & vbCrLf & "        function: {" & vbCrLf & "            name: ""web_search""," & vbCrLf & "            description: ""Search Wikipedia for information. Returns article summary.""," & vbCrLf & "            parameters: {" & vbCrLf & "                type: ""object""," & vbCrLf & "                properties: {" & vbCrLf & "                    query: { type: ""string"", description: ""Search query for Wikipedia"" }" & vbCrLf & "                }," & vbCrLf & "                required: [""query""]" & vbCrLf & "            }" & vbCrLf & "        }" & vbCrLf & "    }," & vbCrLf & "    {" & vbCrLf & "        type: ""function""," & vbCrLf & "        function: {" & vbCrLf & "            name: ""fetch_url""," & vbCrLf & "            description: ""Fetch content from a specific URL. Returns extracted text.""," & vbCrLf & "            parameters: {" & vbCrLf & "                type: ""object""," & vbCrLf & "                properties: {" & vbCrLf & "                    url: { type: ""string"", description: ""Full URL to fetch, e.g. 'https://example.com'"" }" & vbCrLf & "                }," & vbCrLf & "                required: [""url""]" & vbCrLf & "            }" & vbCrLf & "        }" & vbCrLf & "    }," & vbCrLf & "    {" & vbCrLf & "        type: ""function""," & vbCrLf & "        function: {" & vbCrLf & "            name: ""calculate""," & vbCrLf & "            description: ""Perform mathematical calculations""," & vbCrLf & "            parameters: {" & vbCrLf & "                type: ""object""," & vbCrLf & "                properties: {" & vbCrLf & "                    expression: { type: ""string"", description: ""Math expression to evaluate, e.g. '15*200/100'"" }" & vbCrLf & "                }," & vbCrLf & "                required: [""expression""]" & vbCrLf & "            }" & vbCrLf & "        }" & vbCrLf & "    }," & vbCrLf & "    {" & vbCrLf & "        type: ""function""," & vbCrLf & "        function: {" & vbCrLf & "            name: ""save_data""," & vbCrLf & "            description: ""Save data to session storage for later use""," & vbCrLf & "            parameters: {" & vbCrLf & "                type: ""object""," & vbCrLf & "                properties: {" & vbCrLf & "                    key: { type: ""string"", description: ""Name/key for the data"" }," & vbCrLf & "                    value: { type: ""string"", description: ""Value to store"" }" & vbCrLf & "                }," & vbCrLf & "                required: [""key"", ""value""]" & vbCrLf & "            }" & vbCrLf & "        }" & vbCrLf & "    }," & vbCrLf & "    {" & vbCrLf & "        type: ""function""," & vbCrLf & "        function: {" & vbCrLf & "            name: ""get_data""," & vbCrLf & "            description: ""Retrieve previously saved data from session storage""," & vbCrLf & "            parameters: {" & vbCrLf & "                type: ""object""," & vbCrLf & "                properties: {" & vbCrLf & "                    key: { type: ""string"", description: ""Name/key of the data to retrieve"" }" & vbCrLf & "                }," & vbCrLf & "                required: [""key""]" & vbCrLf & "            }" & vbCrLf & "        }" & vbCrLf & "    }," & vbCrLf & "    {" & vbCrLf & "        type: ""function""," & vbCrLf & "        function: {" & vbCrLf & "            name: ""list_data""," & vbCrLf & "            description: ""List all saved data keys in session storage""," & vbCrLf & "            parameters: { type: ""object"", properties: {}, required: [] }" & vbCrLf & "        }" & vbCrLf & "    }," & vbCrLf & "    {" & vbCrLf & "        type: ""function""," & vbCrLf & "        function: {" & vbCrLf & "            name: ""get_current_time""," & vbCrLf & "            description: ""Get the current date and time""," & vbCrLf & "            parameters: { type: ""object"", properties: {}, required: [] }" & vbCrLf & "        }" & vbCrLf & "    }," & vbCrLf & "    {" & vbCrLf & "        type: ""function""," & vbCrLf & "        function: {" & vbCrLf & "            name: ""generate_tweet""," & vbCrLf & "            description: ""Generate a tweet-ready message (max 280 chars)""," & vbCrLf & "            parameters: {" & vbCrLf & "                type: ""object""," & vbCrLf & "                properties: {" & vbCrLf & "                    topic: { type: ""string"", description: ""Topic for the tweet"" }," & vbCrLf & "                    style: { type: ""string"", description: ""Style: funny, professional, casual, inspirational"" }" & vbCrLf & "                }," & vbCrLf & "                required: [""topic""]" & vbCrLf & "            }" & vbCrLf & "        }" & vbCrLf & "    }," & vbCrLf & "    {" & vbCrLf & "        type: ""function""," & vbCrLf & "        function: {" & vbCrLf & "            name: ""generate_content""," & vbCrLf & "            description: ""Generate various types of content: articles, emails, code, stories, summaries, etc.""," & vbCrLf & "            parameters: {" & vbCrLf & "                type: ""object""," & vbCrLf & "                properties: {" & vbCrLf & "                    type: { type: ""string"", description: ""Type of content: article, email, code, story, summary, list, poem"" }," & vbCrLf & "                    topic: { type: ""string"", description: ""Topic or subject of the content"" }," & vbCrLf & "                    length: { type: ""string"", description: ""Length: short, medium, long"" }," & vbCrLf & "                    style: { type: ""string"", description: ""Style: formal, casual, professional, creative"" }" & vbCrLf & "                }," & vbCrLf & "                required: [""type"", ""topic""]" & vbCrLf & "            }" & vbCrLf & "        }" & vbCrLf & "    }" & vbCrLf & "];" & vbCrLf & "" & vbCrLf & "// Tool implementations" & vbCrLf & "async function executeTool(toolName, args) {" & vbCrLf & "    switch(toolName) {" & vbCrLf & "        case ""get_weather"":" & vbCrLf & "            try {" & vbCrLf & "                const geoUrl = 'https://geocoding-api.open-meteo.com/v1/search?name=' + encodeURIComponent(args.city) + '&count=1';" & vbCrLf & "                const geoRes = await fetch(geoUrl);" & vbCrLf & "                if (!geoRes.ok) return 'Error finding city: ' + geoRes.status;" & vbCrLf & "                const geoData = await geoRes.json();" & vbCrLf & "                " & vbCrLf & "                if (!geoData.results || geoData.results.length === 0) {" & vbCrLf & "                    return 'City ""' + args.city + '"" not found';" & vbCrLf & "                }" & vbCrLf & "                " & vbCrLf & "                const lat = geoData.results[0].latitude;" & vbCrLf & "                const lon = geoData.results[0].longitude;" & vbCrLf & "                const cityName = geoData.results[0].name;" & vbCrLf & "                " & vbCrLf & "                const weatherUrl = 'https://api.open-meteo.com/v1/forecast?latitude=' + lat + '&longitude=' + lon + '&current_weather=true';" & vbCrLf & "                const weatherRes = await fetch(weatherUrl);" & vbCrLf & "                if (!weatherRes.ok) return 'Error fetching weather: ' + weatherRes.status;" & vbCrLf & "                const weatherData = await weatherRes.json();" & vbCrLf & "                " & vbCrLf & "                const cw = weatherData.current_weather;" & vbCrLf & "                const temp = cw.temperature;" & vbCrLf & "                const wind = cw.windspeed;" & vbCrLf & "                const desc = cw.weathercode <= 3 ? ""Clear"" : cw.weathercode <= 49 ? ""Cloudy/Foggy"" : cw.weathercode <= 99 ? ""Rain/Drizzle"" : ""Storm/Snow"";" & vbCrLf & "                " & vbCrLf & "                return 'Weather in ' + cityName + ': ' + temp + 'C, ' + desc + ', Wind: ' + wind + ' km/h';" & vbCrLf & "            } catch(e) {" & vbCrLf & "                return 'Error: ' + e.message;" & vbCrLf & "            }" & vbCrLf & "        " & vbCrLf & "        case ""web_search"":" & vbCrLf & "            try {" & vbCrLf & "                const searchUrl = 'https://en.wikipedia.org/api/rest_v1/page/summary/' + encodeURIComponent(args.query);" & vbCrLf & "                const res = await fetch(searchUrl);" & vbCrLf & "                if (!res.ok) {" & vbCrLf & "                    const searchApiUrl = 'https://en.wikipedia.org/w/api.php?action=opensearch&search=' + encodeURIComponent(args.query) + '&limit=3&format=json&origin=*';" & vbCrLf & "                    const searchRes = await fetch(searchApiUrl);" & vbCrLf & "                    if (!searchRes.ok) return 'Wikipedia search failed: ' + searchRes.status;" & vbCrLf & "                    const searchData = await searchRes.json();" & vbCrLf & "                    if (searchData[1] && searchData[1].length > 0) {" & vbCrLf & "                        let results = 'Wikipedia results for ""' + args.query + '"":\n';" & vbCrLf & "                        for (let i = 0; i < searchData[1].length; i++) {" & vbCrLf & "                            results += (i+1) + '. ' + searchData[1][i] + ' - ' + searchData[3][i] + '\n';" & vbCrLf & "                        }" & vbCrLf & "                        return results;" & vbCrLf & "                    }" & vbCrLf & "                    return 'No Wikipedia results for ""' + args.query + '""';" & vbCrLf & "                }" & vbCrLf & "                const data = await res.json();" & vbCrLf & "                return 'Wikipedia: ' + data.title + '\n' + (data.extract || data.description || 'No summary available') + '\nSource: ' + (data.content_urls?.desktop?.page || 'Wikipedia');" & vbCrLf & "            } catch(e) {" & vbCrLf & "                return 'Error: ' + e.message;" & vbCrLf & "            }" & vbCrLf & "        " & vbCrLf & "        case ""fetch_url"":" & vbCrLf & "            try {" & vbCrLf & "                let url = args.url;" & vbCrLf & "                if (!url.startsWith('http')) url = 'https://' + url;" & vbCrLf & "                " & vbCrLf & "                const corsProxies = [" & vbCrLf & "                    'https://api.allorigins.win/raw?url=' + encodeURIComponent(url)," & vbCrLf & "                    'https://corsproxy.io/?' + encodeURIComponent(url)" & vbCrLf & "                ];" & vbCrLf & "                " & vbCrLf & "                let html = null;" & vbCrLf & "                for (const proxyUrl of corsProxies) {" & vbCrLf & "                    try {" & vbCrLf & "                        const res = await fetch(proxyUrl);" & vbCrLf & "                        if (res.ok) {" & vbCrLf & "                            html = await res.text();" & vbCrLf & "                            break;" & vbCrLf & "                        }" & vbCrLf & "                    } catch(e) {}" & vbCrLf & "                }" & vbCrLf & "                " & vbCrLf & "                if (!html) return 'Could not fetch ' + url + '. CORS proxies blocked. Try Wikipedia search instead.';" & vbCrLf & "                " & vbCrLf & "                const text = html.replace(/<script[^>]*>[\s\S]*?<\/script>/gi, '')" & vbCrLf & "                               .replace(/<style[^>]*>[\s\S]*?<\/style>/gi, '')" & vbCrLf & "                               .replace(/<[^>]+>/g, ' ')" & vbCrLf & "                               .replace(/&nbsp;/g, ' ')" & vbCrLf & "                               .replace(/&amp;/g, '&')" & vbCrLf & "                               .replace(/\s+/g, ' ')" & vbCrLf & "                               .substring(0, 3000);" & vbCrLf & "                return 'Content from ' + url + ':\n' + text;" & vbCrLf & "            } catch(e) {" & vbCrLf & "                return 'Error: ' + e.message;" & vbCrLf & "            }" & vbCrLf & "        " & vbCrLf & "        case ""calculate"":" & vbCrLf & "            try {" & vbCrLf & "                const result = Function('""use strict""; return (' + args.expression + ')')();" & vbCrLf & "                return 'Result: ' + args.expression + ' = ' + result;" & vbCrLf & "            } catch(e) {" & vbCrLf & "                return 'Error calculating: ' + e.message;" & vbCrLf & "            }" & vbCrLf & "        " & vbCrLf & "        case ""save_data"":" & vbCrLf & "            sessionData[args.key] = args.value;" & vbCrLf & "            sessionStorage.setItem('pdfclaw_data', JSON.stringify(sessionData));" & vbCrLf & "            return 'Saved: ' + args.key + ' = ""' + args.value + '""';" & vbCrLf & "        " & vbCrLf & "        case ""get_data"":" & vbCrLf & "            const value = sessionData[args.key];" & vbCrLf & "            if (value !== undefined) {" & vbCrLf & "                return 'Retrieved: ' + args.key + ' = ""' + value + '""';" & vbCrLf & "            }" & vbCrLf & "            return 'No data found for key: ' + args.key;" & vbCrLf & "        " & vbCrLf & "        case ""list_data"":" & vbCrLf & "            const keys = Object.keys(sessionData);" & vbCrLf & "            if (keys.length === 0) return ""No saved data found."";" & vbCrLf & "            return 'Saved data keys: ' + keys.join(', ') + '\nData: ' + JSON.stringify(sessionData, null, 2);" & vbCrLf & "        " & vbCrLf & "        case ""get_current_time"":" & vbCrLf & "            const now = new Date();" & vbCrLf & "            return 'Current time: ' + now.toLocaleString();" & vbCrLf & "        " & vbCrLf & "        case ""generate_tweet"":" & vbCrLf & "            return 'Generate a tweet about ""' + args.topic + '"" (style: ' + (args.style || 'casual') + '). Keep it under 280 characters. Return ONLY the tweet text.';" & vbCrLf & "        " & vbCrLf & "        case ""generate_content"":" & vbCrLf & "            const length = args.length || 'medium';" & vbCrLf & "            const style = args.style || 'professional';" & vbCrLf & "            return 'Generate a ' + length + ' ' + args.type + ' about ""' + args.topic + '"" in ' + style + ' style. Return ONLY the content, no explanations.';" & vbCrLf & "        " & vbCrLf & "        default:" & vbCrLf & "            return 'Unknown tool: ' + toolName;" & vbCrLf & "    }" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "let messages = [" & vbCrLf & "    { " & vbCrLf & "        role: ""system"", " & vbCrLf & "        content: ""You are a helpful AI assistant with access to tools. When you need to search the web, calculate, save/retrieve data, or perform specific tasks, use the appropriate tool. Always be helpful and concise. After using a tool, explain the result to the user naturally.""" & vbCrLf & "    }" & vbCrLf & "];" & vbCrLf & "" & vbCrLf & "inputEl.addEventListener(""keydown"", function(e) {" & vbCrLf & "    if (e.key === ""Enter"" && !sendBtn.disabled) sendMessage();" & vbCrLf & "});" & vbCrLf & "" & vbCrLf & "function addMsg(text, cls) {" & vbCrLf & "    const div = document.createElement(""div"");" & vbCrLf & "    div.className = ""msg "" + cls;" & vbCrLf & "    div.textContent = text;" & vbCrLf & "    chatEl.appendChild(div);" & vbCrLf & "    chatEl.scrollTop = chatEl.scrollHeight;" & vbCrLf & "    return div;" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "async function sendMessage() {" & vbCrLf & "    const msg = inputEl.value.trim();" & vbCrLf & "    if (!msg) return;" & vbCrLf & "    " & vbCrLf & "    if (!API_KEY) {" & vbCrLf & "        addMsg(""Please enter your Together API key above first!"", ""system"");" & vbCrLf & "        apiKeyInput.focus();" & vbCrLf & "        return;" & vbCrLf & "    }" & vbCrLf & "    " & vbCrLf & "    addMsg(msg, ""user"");" & vbCrLf & "    inputEl.value = """";" & vbCrLf & "    sendBtn.disabled = true;" & vbCrLf & "    " & vbCrLf & "    messages.push({ role: ""user"", content: msg });" & vbCrLf & "    " & vbCrLf & "    const typing = addMsg(""Thinking..."", ""ai typing"");" & vbCrLf & "    " & vbCrLf & "    try {" & vbCrLf & "        let response = await callAI();" & vbCrLf & "        typing.textContent = response;" & vbCrLf & "        typing.className = ""msg ai"";" & vbCrLf & "    } catch(e) {" & vbCrLf & "        typing.textContent = ""Error: "" + e.message;" & vbCrLf & "        typing.className = ""msg ai error"";" & vbCrLf & "    }" & vbCrLf & "    " & vbCrLf & "    sendBtn.disabled = false;" & vbCrLf & "    inputEl.focus();" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "async function callAI() {" & vbCrLf & "    const res = await fetch(API_URL, {" & vbCrLf & "        method: ""POST""," & vbCrLf & "        headers: {" & vbCrLf & "            ""Content-Type"": ""application/json""," & vbCrLf & "            ""Authorization"": ""Bearer "" + API_KEY" & vbCrLf & "        }," & vbCrLf & "        body: JSON.stringify({" & vbCrLf & "            model: MODEL," & vbCrLf & "            messages: messages," & vbCrLf & "            tools: tools," & vbCrLf & "            tool_choice: ""auto""," & vbCrLf & "            max_tokens: 1024" & vbCrLf & "        })" & vbCrLf & "    });" & vbCrLf & "    " & vbCrLf & "    if (!res.ok) {" & vbCrLf & "        const errText = await res.text();" & vbCrLf & "        throw new Error('API Error: ' + res.status + ' - ' + errText.substring(0, 100));" & vbCrLf & "    }" & vbCrLf & "    " & vbCrLf & "    const data = await res.json();" & vbCrLf & "    const assistantMsg = data.choices[0].message;" & vbCrLf & "    " & vbCrLf & "    messages.push(assistantMsg);" & vbCrLf & "    " & vbCrLf & "    if (assistantMsg.tool_calls && assistantMsg.tool_calls.length > 0) {" & vbCrLf & "        for (const toolCall of assistantMsg.tool_calls) {" & vbCrLf & "            const toolName = toolCall.function.name;" & vbCrLf & "            const args = JSON.parse(toolCall.function.arguments);" & vbCrLf & "            addMsg('Tool: ' + toolName + '(' + JSON.stringify(args) + ')', ""tool"");" & vbCrLf & "            " & vbCrLf & "            const result = await executeTool(toolName, args);" & vbCrLf & "            addMsg('Result: ' + result, ""tool"");" & vbCrLf & "            " & vbCrLf & "            messages.push({" & vbCrLf & "                role: ""tool""," & vbCrLf & "                tool_call_id: toolCall.id," & vbCrLf & "                content: result" & vbCrLf & "            });" & vbCrLf & "        }" & vbCrLf & "        " & vbCrLf & "        const finalRes = await fetch(API_URL, {" & vbCrLf & "            method: ""POST""," & vbCrLf & "            headers: {" & vbCrLf & "                ""Content-Type"": ""application/json""," & vbCrLf & "                ""Authorization"": ""Bearer "" + API_KEY" & vbCrLf & "            }," & vbCrLf & "            body: JSON.stringify({" & vbCrLf & "                model: MODEL," & vbCrLf & "                messages: messages," & vbCrLf & "                max_tokens: 1024" & vbCrLf & "            })" & vbCrLf & "        });" & vbCrLf & "        " & vbCrLf & "        if (!finalRes.ok) throw new Error(""Failed to get final response"");" & vbCrLf & "        " & vbCrLf & "        const finalData = await finalRes.json();" & vbCrLf & "        const finalMsg = finalData.choices[0].message;" & vbCrLf & "        messages.push(finalMsg);" & vbCrLf & "        return finalMsg.content;" & vbCrLf & "    }" & vbCrLf & "    " & vbCrLf & "    return assistantMsg.content || ""No response"";" & vbCrLf & "}" & vbCrLf & "</script>" & vbCrLf & "</body>" & vbCrLf & "</html>"
    
